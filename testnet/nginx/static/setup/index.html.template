<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="./style/base.css">
    <title>Logos Devnet</title>
</head>
<body>
    <a class="logo" href="./"><img class="icon-svg" src="./assets/logos.svg" /></a>
    <h1>Logos Blockchain Info Page</h1>

    <div class="warning">
        <h3>Environment is in a setup mode.<h3>
    </div>

    <h2>Nodes</h2>
    <ul class="node-list">
        <li>
            <span class="node-label">Node 0:</span>
            <div class="node-links">
                <a href="https://$ENV_TITLE_STRING.blockchain.logos.co/internal/node-data/0/config.yaml" target="_blank">Config</a>
            </div>
        </li>

        <li>
            <span class="node-label">Node 1:</span>
            <div class="node-links">
                <a href="https://$ENV_TITLE_STRING.blockchain.logos.co/internal/node-data/1/config.yaml" target="_blank">Config</a>
            </div>
        </li>

        <li>
            <span class="node-label">Node 2:</span>
            <div class="node-links">
                <a href="https://$ENV_TITLE_STRING.blockchain.logos.co/internal/node-data/2/config.yaml" target="_blank">Config</a>
            </div>
        </li>

        <li>
            <span class="node-label">Node 3:</span>
            <div class="node-links">
                <a href="https://$ENV_TITLE_STRING.blockchain.logos.co/internal/node-data/3/config.yaml" target="_blank">Config</a>
            </div>
        </li>
    </ul>

    <h2>Tools</h2>
    <ul>
        <li>
            <a href="https://$ENV_TITLE_STRING.blockchain.logos.co/web/cfgsync/deployment-settings" target="_blank">Deployment Settings (In Browser)</a>
        </li>
        <li>
            <a href="https://$ENV_TITLE_STRING.blockchain.logos.co/internal/node-data/cfgsync/deployment-settings.yaml" target="_blank">Deployment Settings (File Download)</a>
        </li>
        <li>
            <a href="https://$ENV_TITLE_STRING.blockchain.logos.co/internal/node-data/" target="_blank">Node Data</a>
        </li>
    </ul>

    <h2>External</h2>
    <ul>
        <li>
            <a href="https://www.notion.so/nomos-tech/Joining-the-Devnet-313261aa09df80d2b894d1c32abb6954" target="_blank">Notion</a>
        </li>
        <li>
            <a href="https://github.com/logos-blockchain/logos-blockchain/releases" target="_blank">Releases</a>
        </li>
    </ul>
</body>
</html>
